# ============================================================
# Binance Spot Trading Bot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------- Application ----------
APP_ENV=development                    # development | staging | production
TRADING_MODE=paper                     # paper | live  (paper is default and safe)

# ---------- Binance API ----------
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_BASE_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
ENABLE_TELEGRAM=false

# ---------- Trading Parameters ----------
DEFAULT_QUOTE_ASSET=USDT
TRADE_SYMBOLS=["BTCUSDT","ETHUSDT","BNBUSDT"]
TRADE_INTERVAL=1h

# ---------- Risk Management ----------
MAX_RISK_PER_TRADE=0.02                # 2% of portfolio per trade
MAX_DAILY_LOSS_PCT=0.05                # 5% max daily loss
MAX_OPEN_POSITIONS=5                   # Allow concurrent positions across symbols
MAX_POSITION_SIZE_PCT=0.40             # 40% max per position (patient entries)
STOP_LOSS_PCT=0.05                     # 5% default stop-loss (room for mean reversion)

# ---------- Safety ----------
ENABLE_LIVE_TRADING=false              # MUST be explicitly set to true
ENABLE_KILL_SWITCH=false               # Emergency halt

# ---------- Fees ----------
SLIPPAGE_BPS=10                        # 10 basis points
TAKER_FEE_BPS=10                       # 10 basis points
MAKER_FEE_BPS=10                       # 10 basis points

# ---------- Database ----------
DATABASE_URL=sqlite:///data/trading_bot.db

# ---------- Research / Backtest ----------
BACKTEST_SYMBOLS=["BTCUSDT","ETHUSDT","BNBUSDT"]   # JSON array of symbol pairs
BACKTEST_INTERVALS=["15m","1h","4h"]               # JSON array of valid intervals
BACKTEST_LOOKBACK_DAYS=180                  # Days of history per evaluation

# ---------- Qualification Thresholds ----------
QUAL_MIN_RETURN_PCT=0              # Min total return (0 = breakeven)
QUAL_MIN_SHARPE=0                  # Min Sharpe ratio
QUAL_MIN_TRADES=5                  # Min trade count
QUAL_MAX_DRAWDOWN_PCT=0.30         # Max drawdown (0.30 = 30%)
QUAL_MIN_PROFIT_FACTOR=0.8         # Min profit factor
QUAL_MIN_OOS_CONSISTENCY=0         # Min OOS consistency (0-1)
QUAL_MIN_BENCHMARK_ALPHA_PCT=0     # Min alpha vs buy-and-hold
QUAL_MIN_DATASET_PASS_RATE=0.5     # Min fraction of datasets that must qualify (0-1)

# ---------- Regime Gating ----------
REGIME_MIN_VOLATILITY_PCT=0.2      # Skip quiet markets (ATR% < this)
REGIME_MAX_VOLATILITY_PCT=8.0      # Skip wild markets (ATR% > this)
ENABLE_REGIME_GATING=true           # Enable regime gating in paper trading

# ---------- Web Dashboard ----------
WEB_PORT=8880                      # Port for the web management dashboard
SESSION_TTL_HOURS=24               # Login session duration in hours
